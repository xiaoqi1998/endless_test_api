# Endless Test API 环境变量模板
# 复制为 .env 后按需修改

# 服务端口
ENDLESS_SIDECAR_PORT=3001

# Endless 网络名称（devnet / testnet / mainnet）
ENDLESS_NETWORK=devnet

# RPC 节点地址
ENDLESS_NETWORK_URL=https://api.devnet.endlesslabs.com/v1

# 默认签名私钥（可选，用于未显式传入私钥的写交易接口）
SIGNER_PRIVATE_KEY=

# 管理接口 Token（可选）。若设置，则调用 /admin/network 切换网络时必须携带 Authorization: Bearer <token>
ADMIN_TOKEN=
