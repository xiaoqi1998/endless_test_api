{
  "compilerOptions": {
    // 基础选项
    "target": "es2020",                            /* 编译目标 JavaScript 版本 */
    "module": "commonjs",                          /* 指定模块代码生成 */
    "rootDir": "./",                               /* 指定输入文件的根目录 */
    "outDir": "./dist",                            /* 指定输出目录 */
    "esModuleInterop": true,                       /* 启用 CommonJS 和 ES 模块之间的互操作性 */
    "forceConsistentCasingInFileNames": true,      /* 强制文件名大小写一致 */
    "strict": true,                                /* 启用所有严格类型检查选项 */
    "skipLibCheck": true,                          /* 跳过库声明文件的类型检查 */

    // 模块解析选项
    "moduleResolution": "node",                    /* 模块解析策略 */
    "resolveJsonModule": true                      /* 允许导入 .json 文件 */
  },
  "include": ["**/*.ts"],                           /* 包含所有 .ts 文件 */
  "exclude": [
    "../node_modules"
  ]                       /* 排除 node_modules 文件夹 */
}